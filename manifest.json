{
  "manifest_version": 3,
  "name": "Google Meeet Color Toggle",
  "version": "0.1",
  "author": "Tipu Sultan Eiko",
  "description": "Switch google meet color variation to dark or light mode.",
  "content_scripts": [
    {
      "matches": ["https://meet.google.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
